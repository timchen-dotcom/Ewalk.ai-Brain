<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.ewalk.obsidian-brain-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/chenjinting/Desktop/Ewalk.ai 自動化系統/Ewalk.ai Brain/腳本/同步到GitHub.sh</string>
  </array>

  <key>StartInterval</key>
  <integer>300</integer>

  <key>RunAtLoad</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/ewalk-obsidian-brain-sync.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/ewalk-obsidian-brain-sync.err</string>
</dict>
</plist>
